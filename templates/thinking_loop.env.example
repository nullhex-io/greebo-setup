# Thinking loop secrets - copy to ~/dev/memory/thinking_loop.env
# NEVER commit this file

# Vercel (for deploy status checks)
VERCEL_TOKEN=your_vercel_token_here

# Supabase (for health checks)
SUPABASE_TOKEN=your_supabase_token_here
SUPABASE_REF=your_project_ref_here

# Sites to check (comma-separated URLs)
SITE_URLS=https://yourapp.com,https://api.yourapp.com

# Git repos to check (comma-separated directory names under ~/dev/)
PROJECT_DIRS=myapp,mywebsite

# xAI API key for AI feed (optional)
# XAI_API_KEY=your_xai_key_here
